{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python: Uvicorn main:app",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": false,
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "./src"
            }
        }
    ]
}
